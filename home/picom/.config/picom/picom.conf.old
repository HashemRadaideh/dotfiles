# picom (yshui) - blur + transparency focused, tuned for smooth GLX + dual Kawase
# Docs: https://picom.app/   |   man picom

#################################
# Blur (dual_kawase = Kawase stack blur, fast on GPU)
#################################

blur: {
  method   = "dual_kawase";
  # Raise for stronger frosted glass (more GPU); try 4–7
  strength = 5;
}

blur-background        = true;
blur-background-frame  = false;
blur-background-fixed  = false;

#################################
# Transparency / frame
#################################

frame-opacity        = 1.0;
transparent-clipping = false;

#################################
# Shadows / fade / corners
#################################

shadow         = false;
fading         = false;
no-fading-openclose       = true;
no-fading-destroyed-argb  = true;
corner-radius  = 0;

#################################
# Core compositor
#################################

daemon  = true;
backend = "glx";
vsync   = true;
dbus    = false;

dithered-present = false;

# Saves a bit of CPU; unrelated to corner-radius (that is client-side shape detection)
detect-rounded-corners = false;

detect-client-opacity = true;
detect-transient      = true;
detect-client-leader  = true;
use-ewmh-active-win   = true;

# Unredirect fullscreen opaque windows — big win for games / video
unredir-if-possible        = true;
unredir-if-possible-delay  = 0;

use-damage          = true;
force-win-blend     = false;
no-ewmh-fullscreen  = false;
max-brightness      = 1.0;

# NVIDIA explicit sync: keep true on proprietary drivers; try false on AMD/Intel if latency matters
xrender-sync-fence = true;

log-level = "warn";

glx-copy-from-front = false;
dbe                 = false;

# Animations off (enable via man ANIMATIONS if you want scripted motion)
animations = false;

#################################
# Window rules (v13 — replaces opacity-rule, blur-background-exclude, focus-exclude, etc.)
#################################

rules: (
  {
    match = "window_type = 'tooltip'";
    fade  = false;
    opacity = 0.92;
    full-shadow = false;
  },
  # {
  #   # Layers that sit on top of the root pixmap (not the pixmap itself — picom cannot “exclude” root).
  #   # awful.wallpaper() draws via root.wallpaper(); there is no wallpaper client to match.
  #   # This covers EWMH desktop/dock, GTK CSD, and Awesome wiboxen (bars, etc.) if they are not dock-typed.
  #   match = "window_type = 'desktop' || window_type = 'dock' || _GTK_FRAME_EXTENTS@ || "
  #           "class_g = 'awesome' || class_i = 'awesome'";
  #   blur-background = false;
  #   corner-radius   = 0;
  # },
  # {
  #   match = "class_g = 'feh' || class_g ?= 'Nitrogen' || class_g ?= 'xfdesktop'";
  #   blur-background = false;
  # },
  {
    match = "name = 'Slop' || name = 'slop' || class_g = 'slop' || class_g ?= 'slop'";
    blur-background = false;
    corner-radius   = 0;
  },
  {
    match = "class_g ?= 'zoom' || name *= 'Zoom Meeting' || "
            "class_g ?= 'microsoft teams - preview' || class_g ?= 'Microsoft Teams - Preview'";
    blur-background = false;
    corner-radius   = 0;
    # Do not treat Zoom/Teams fullscreen as unredirect (avoids black/flicker with compositing)
    unredir           = false;
  },
  {
    match = "class_g = 'Rofi'";
    opacity = 0.9;
  },
  {
    match = "fullscreen";
    corner-radius = 0;
  }
)

# Transparent terminals: set opacity in the terminal (e.g. kitty background_opacity) and/or add e.g.
#   { match = "class_g = 'kitty' && !focused"; opacity = 0.92; },
# Blur only appears where the window is actually translucent (ARGB / fractional opacity).
